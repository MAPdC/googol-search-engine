# Maven
target/
.mvn/wrapper/maven-wrapper.properties
!**/src/main/**/target/
!**/src/test/**/target/

# Runtime-generated Barrel snapshots
# Binary serialised index files — machine-specific, auto-regenerated
# Never commit these, they can be large and contain crawled data
barrel-snapshots/

